{
  "buildCommand": "next build",
  "redirects": [
    {
      "source": "/nl/reviews/:slug",
      "destination": "/reviews/:slug",
      "statusCode": 301
    },
    {
      "source": "/kategori/:slug",
      "destination": "/categorieen/:slug",
      "statusCode": 301
    },
    {
      "source": "/kategoriler/:slug",
      "destination": "/categorieen/:slug",
      "statusCode": 301
    },
    {
      "source": "/about",
      "destination": "/over-ons",
      "statusCode": 301
    },
    {
      "source": "/hakkimizda",
      "destination": "/over-ons",
      "statusCode": 301
    },
    {
      "source": "/comparison",
      "destination": "/vergelijking",
      "statusCode": 301
    },
    {
      "source": "/karsilastirma",
      "destination": "/vergelijking",
      "statusCode": 301
    },
    {
      "source": "/contact-us",
      "destination": "/contact",
      "statusCode": 301
    },
    {
      "source": "/reviews/happy-juice-review/",
      "destination": "/reviews/happy-juice-bijwerkingen-huid",
      "statusCode": 301
    },
    {
      "source": "/reviews/mentabiotics-review/",
      "destination": "/reviews/darmbacteriën-gezondheid-mentabiotics",
      "statusCode": 301
    },
    {
      "source": "/reviews/edge-plus/",
      "destination": "/reviews/edge-plus-focus-concentratie",
      "statusCode": 301
    }
  ],
  "headers": [
    {
      "source": "/:path*",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "SAMEORIGIN"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; font-src 'self' data:; img-src 'self' data: https:; connect-src 'self' https://amarenl.com; frame-ancestors 'none'; base-uri 'self';"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=()"
        }
      ]
    },
    {
      "source": "/images/:path*",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/fonts/:path*",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
